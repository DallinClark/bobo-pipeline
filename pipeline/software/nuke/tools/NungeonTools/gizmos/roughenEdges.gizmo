set cut_paste_input [stack 0]
version 11.2 v5
push $cut_paste_input
Group {
 name pp_roughen_edges
 tile_color 0xa57aaaff
 selected true
 xpos -328
 ypos 359
 addUserKnob {20 controls l Controls}
 addUserKnob {22 intN l "Internal Noise" t "Uses internal noise \ngenerated from controls" +DISABLED T "node = nuke.thisNode()\nnode.knobs()\['intNoise'].setVisible(True)\nnode\[\"intN\"].setEnabled(False)\nnode\[\"anim\"].setEnabled(True)\nnode\[\"track\"].setEnabled(True)\nnode\[\"extN\"].setEnabled(True)\n\nswitchnode = nuke.toNode(\"Switch1\")\nswitchnode\[\"which\"].setValue(0)\n\ninputnode = nuke.toNode(\"Inputnoise\")\nnuke.delete(inputnode)" +STARTLINE}
 addUserKnob {22 extN l "External Noise" t "Creates an input for a \ncustom noise map" -STARTLINE T "node = nuke.thisNode()\nnode.knobs()\['intNoise'].setVisible(False)\nnode\[\"intN\"].setEnabled(True)\nnode\[\"anim\"].setEnabled(False)\nnode\[\"track\"].setEnabled(False)\nnode\[\"extN\"].setEnabled(False)\n\nswitchnode = nuke.toNode(\"Switch1\")\ncropnode = nuke.toNode(\"Crop3\")\nswitchnode\[\"which\"].setValue(1)\n\ninputnode = nuke.nodes.Input()\ninputnode\[\"name\"].setValue(\"Inputnoise\")\n\ncropnode.setInput(0,inputnode)\n"}
 addUserKnob {26 ""}
 addUserKnob {20 edge l "Edge Controls" n 1}
 addUserKnob {14 erode l Erode R 0 100}
 addUserKnob {14 blur l Blur R 0 100}
 blur 25
 addUserKnob {20 endGroup n -1}
 addUserKnob {14 amount l Amount R 0 100}
 amount 25
 addUserKnob {26 ""}
 addUserKnob {20 intNoise l "Internal Noise" n 1}
 addUserKnob {14 size l Size R 0 100}
 size 50
 addUserKnob {7 detail l Detail R 0 100}
 detail 2
 addUserKnob {7 seed l Seed R 0 10}
 addUserKnob {20 endGroup_1 l endGroup n -1}
 addUserKnob {20 endGroup_2 l endGroup n -1}
 addUserKnob {20 anim l Animation}
 addUserKnob {6 enableAnim l "Enable Animation" +STARTLINE}
 addUserKnob {7 animspeed l Speed R 0 100}
 animspeed 1
 addUserKnob {20 track l Tracking}
 addUserKnob {41 translate T noiseTrans.translate}
 addUserKnob {41 rotate T noiseTrans.rotate}
 addUserKnob {41 scale T noiseTrans.scale}
 addUserKnob {20 info}
 addUserKnob {26 author l Author: T "Phil Prates - pratesphil@gmail.com"}
 addUserKnob {26 ver l Version: T 1.3}
 addUserKnob {26 changelog l "" +STARTLINE +INVISIBLE T "1.0 - First public release of roughen_edges\n1.1 - Removed mask controls\n       - Changed to pp_blur and pp_erode for edge controls\n       - Changed to work on BBox only for better speed and fixes format problems\n1.3 - Fixed various bugs, and added transform jack for manual noise tracking"}
}
