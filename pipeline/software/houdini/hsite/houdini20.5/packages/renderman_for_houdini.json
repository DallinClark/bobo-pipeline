{
    "load_package_once": true,
    "env": [
        {
            "RMANTREE": {"houdini_os == 'linux'": "/groups/dungeons/production/opt/pixar/RenderManProServer-26.3"}
        },
        {
            "RMANTREE": {"houdini_os == 'windows'": "G:/dungeons/production/PFiles/Pixar/RenderManProServer-26.3"}
        },
        {
            "RFHTREE": {"houdini_os == 'linux'": "/groups/dungeons/production/opt/pixar/RenderManForHoudini-26.3"}
        },
        {
            "RFHTREE": {"houdini_os == 'windows'": "G:/dungeons/production/PFiles/Pixar/RenderManForHoudini-26.3/"}

        },
        {
            "RFH_HOUDINI_VERS" :
            [
                {"houdini_version<'21.0' and houdini_version>='20.5.278'": "20.5.278"},
                {"houdini_version<'20.5.278' and houdini_version>='20.5.278'": "20.5.278"},
                {"houdini_version<'20.5' and houdini_version>='20.0.751'": "20.0.751"},
                {"houdini_version<'20.0.751' and houdini_version>='20.0.751'": "20.0.751"},
                {"houdini_version<'20.0.751' and houdini_version>='20.0.724'": "20.0.724"},
                {"houdini_version<'20.0.724' and houdini_version>='20.0.724'": "20.0.724"},
                {"houdini_version<'20.0.724' and houdini_version>='20.0.653'": "20.0.653"},
                {"houdini_version<'20.0.653' and houdini_version>='20.0.653'": "20.0.653"}
            ]
        },
        {
            "RFH_PY_VERS":
            [
                { "houdini_python=='python2'": "2.7" },
                { "houdini_python=='python3' and houdini_version<'19.5'": "3.7" },
                { "houdini_python=='python3.7'": "3.7" },
                { "houdini_python=='python3.9'": "3.9" },
                { "houdini_python=='python3.10'": "3.10" },
                { "houdini_python=='python3.11'": "3.11" }
            ]
        },
        { "HOUDINI_PATH": "${RFHTREE}/${RFH_PY_VERS}/${RFH_HOUDINI_VERS}" },
        {
            "RMAN_PROCEDURALPATH": 
            {
                "value": "${RFHTREE}/${RFH_PY_VERS}/${RFH_HOUDINI_VERS}/openvdb",
                "method": "prepend"
            } 
        }
    ]
}
